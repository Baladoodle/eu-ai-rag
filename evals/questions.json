{
  "$schema": "./questions.schema.json",
  "version": "1.0.0",
  "description": "20 Q&A pairs that exercise the mastra-expert RAG. Each case is hand-written after reading the official Mastra docs (https://mastra.ai/docs). Categories are balanced and difficulty is split 8 easy / 8 medium / 4 hard. Run with: npm run eval.",
  "cases": [
    {
      "id": "q01",
      "category": "agents",
      "difficulty": "easy",
      "question": "What is Mastra and what are its main features?",
      "expectedSources": [
        "https://mastra.ai/docs",
        "https://mastra.ai/docs/agents/overview"
      ],
      "expectedTopics": [
        "agents",
        "workflows",
        "RAG",
        "TypeScript framework"
      ]
    },
    {
      "id": "q02",
      "category": "agents",
      "difficulty": "easy",
      "question": "How do I create a basic Mastra agent?",
      "expectedSources": [
        "https://mastra.ai/docs/agents/overview"
      ],
      "expectedTopics": [
        "createAgent",
        "model",
        "instructions",
        "generate"
      ]
    },
    {
      "id": "q03",
      "category": "rag",
      "difficulty": "easy",
