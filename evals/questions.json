  "description": "20 Q&A pairs that exercise the eu-ai-act-expert RAG over Regulation (EU) 2024/1689. Each case is hand-written after reading the official text (https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32024R1689). Categories reflect EU AI Act topics; difficulty is split 8 easy / 8 medium / 4 hard. Run with: npm run eval -- --mock.",
  "cases": [
    {
      "id": "q01",
      "category": "risk-classification",
      "difficulty": "easy",
      "question": "What are the four risk categories used by the EU AI Act?",
      "expectedSources": [
        "https://artificialintelligenceact.eu/article/50/",
        "https://artificialintelligenceact.eu/article/5/"
      ],
      "expectedTopics": [
        "unacceptable risk",
        "high risk",
        "limited risk",
        "minimal risk"
      ]
    },
    {
