# mastra-expert — environment variables
# Copy to `.env.local` for local dev. Production values are set in Vercel.
# See ARCHITECTURE.md §10 for the full table.

# --- LLM -------------------------------------------------------------------
# Anthropic API key (Claude). Required in prod. Mocked in dev with MOCK=1.
ANTHROPIC_API_KEY=

# Anthropic base URL. Defaults to the official API. Override to route
# through an Anthropic-compatible proxy (e.g. MiniMax, AWS Bedrock gateway,
# internal mirror). The key + URL combination determines the upstream.
# ANTHROPIC_BASE_URL=

# --- Embeddings -------------------------------------------------------------
# Voyage AI key for voyage-code-3 embeddings. Required in prod. Mocked in dev.
VOYAGE_API_KEY=

# --- Vector store -----------------------------------------------------------
# Supabase / pgvector connection string. Required for the `pg` vector backend.
# When unset, the app falls back to the in-memory store automatically.
POSTGRES_CONNECTION_STRING=

# `pg` (default in prod) or `memory` (default in dev). Override to force one.
VECTOR_BACKEND=

# --- Behavior toggles -------------------------------------------------------
# Set to 1 to run with MSW-mocked Anthropic + Voyage. The "no API keys" path.
MOCK=

# `trace` | `debug` | `info` | `warn` | `error`. Defaults: info in prod, debug in dev.
LOG_LEVEL=

# Claude model id. Defaults to claude-sonnet-4-5.
MODEL_ID=

# --- Ingestion pipeline -----------------------------------------------------
# Voyage AI is the default; OpenAI is a fallback. Set both provider and
# model together — they must match. See src/lib/env.ts for the enum.
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-code-3
OPENAI_API_KEY=

# Pin the Git ref of the mastra-ai/mastra repo that the source scraper
# clones. Default: main. Pin to a tag (e.g. v0.10.0) for reproducible KBs.
MASTRA_REF=main

# Cap on items ingested per source. Useful while iterating.
# INGEST_LIMIT=10

# Set to 1 to default the CLI into dry-run mode (scrape + chunk only,
# no embedding, no upsert). CI smoke tests use this.
DRY_RUN=
