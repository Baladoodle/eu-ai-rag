# mastra-expert — environment variables
# Copy to `.env.local` for local dev. Production values are set in Vercel.
# See ARCHITECTURE.md §10 for the full table.

# --- LLM -------------------------------------------------------------------
# Anthropic API key (Claude). Required in prod. Mocked in dev with MOCK=1.
ANTHROPIC_API_KEY=

# --- Embeddings -------------------------------------------------------------
# Voyage AI key for voyage-code-3 embeddings. Required in prod. Mocked in dev.
VOYAGE_API_KEY=

# --- Vector store -----------------------------------------------------------
# Supabase / pgvector connection string. Required for the `pg` vector backend.
# When unset, the app falls back to the in-memory store automatically.
POSTGRES_CONNECTION_STRING=

# `pg` (default in prod) or `memory` (default in dev). Override to force one.
VECTOR_BACKEND=

# --- Behavior toggles -------------------------------------------------------
# Set to 1 to run with MSW-mocked Anthropic + Voyage. The "no API keys" path.
MOCK=

# `trace` | `debug` | `info` | `warn` | `error`. Defaults: info in prod, debug in dev.
LOG_LEVEL=

# Claude model id. Defaults to claude-sonnet-4-5.
MODEL_ID=
